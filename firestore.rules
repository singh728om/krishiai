
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /farmServices/{serviceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.providerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.providerId == request.auth.uid;
    }

    match /equipmentServices/{serviceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.providerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.providerId == request.auth.uid;
    }

    match /laborServices/{serviceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.providerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.providerId == request.auth.uid;
    }

    match /crops/{cropId} {
      allow read: if isSignedIn();
    }
    
    match /diseases/{diseaseId} {
      allow read: if isSignedIn();
    }
  }
}
