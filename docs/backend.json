
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user of the KrishiAI platform, primarily a farmer. This entity stores profile information, not authentication credentials.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "village": { "type": "string" },
        "district": { "type": "string" },
        "pincode": { "type": "string" },
        "languagePreference": { "type": "string" },
        "subscriptionPlan": { "type": "string" },
        "farmIds": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["farmer", "internal_ops", "consumer"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "phone"]
    },
    "FarmService": {
      "title": "FarmService",
      "type": "object",
      "description": "Services listed by providers (tractors, labor, seed shops).",
      "properties": {
        "id": { "type": "string" },
        "providerId": { "type": "string" },
        "category": { "type": "string", "enum": ["Equipment", "Labor", "Inputs"] },
        "type": { "type": "string", "description": "e.g., Tractor, Sowing Labor, Seed Shop" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string", "enum": ["hour", "day", "acre", "unit"] },
        "village": { "type": "string" },
        "district": { "type": "string" },
        "pincode": { "type": "string" },
        "phone": { "type": "string" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["Available", "Busy", "Closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LeasePlot": {
      "title": "LeasePlot",
      "type": "object",
      "description": "A plot of land leased by the company for organic cultivation.",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "district": { "type": "string" },
        "village": { "type": "string" },
        "acreage": { "type": "number" },
        "soilType": { "type": "string" },
        "irrigation": { "type": "boolean" },
        "annualRent": { "type": "number" },
        "currentCrop": { "type": "string" },
        "monitorId": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Pending", "Under Inspection", "Expired"] },
        "leaseStart": { "type": "string", "format": "date" },
        "leaseEnd": { "type": "string", "format": "date" }
      }
    },
    "StoreProduct": {
      "title": "StoreProduct",
      "type": "object",
      "description": "Organic products sold through Harit Store.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "originPlotId": { "type": "string" },
        "stock": { "type": "number" },
        "harvestDate": { "type": "string", "format": "date" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profiles."
        }
      },
      {
        "path": "/farmServices/{serviceId}",
        "definition": {
          "entityName": "FarmService",
          "schema": { "$ref": "#/backend/entities/FarmService" },
          "description": "Marketplace for tractors, labor, and inputs."
        }
      },
      {
        "path": "/leasePlots/{plotId}",
        "definition": {
          "entityName": "LeasePlot",
          "schema": { "$ref": "#/backend/entities/LeasePlot" },
          "description": "Company leased plots."
        }
      },
      {
        "path": "/storeProducts/{productId}",
        "definition": {
          "entityName": "StoreProduct",
          "schema": { "$ref": "#/backend/entities/StoreProduct" },
          "description": "Store inventory."
        }
      }
    ]
  }
}
